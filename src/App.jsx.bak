  { icon: <FaProjectDiagram />, hi: "एंड-टू-एंड सोच", en: "End-to-End Thinking", desc: "फ्रंटएंड और बैकएंड दोनों समझें, एक वर्सटाइल इंजीनियर बनें जो बड़ी तस्वीर देखता है।" },
  { icon: <FaCertificate />, hi: "करियर ग्रोथ", en: "Career Growth", desc: "एक मज़बूत फाउंडेशन जो SDE, प्रोडक्ट और लीडरशिप रोल्स के दरवाज़े खोलता है।" },
  { icon: <FaUsers />, hi: "फ्यूचर-प्रूफ", en: "Future-Proof", desc: "हर कंपनी सॉफ्टवेयर कंपनी बन रही है। AI युग में वेब डेवलपमेंट स्किल्स ज़रूरी रहेंगी।" },
  { icon: <FaGraduationCap />, hi: "डिग्री + स्किल्स", en: "Degree + Skills", desc: "BCA/BSc डिग्री को प्रैक्टिकल, एम्प्लॉयेबल, प्रोजेक्ट-बेस्ड एक्सपर्टीज़ के साथ पूरा करता है।" },
];

function WhyFullstack() {
  return (
    <section className="section why-section" id="why"><div className="container">
      <motion.div className="text-center" {...reveal()}><span className="section-tag">करियर / Career</span><h2 className="section-title">क्यों <span className="gradient-text">फुलस्टैक डेवलपमेंट?</span><span className="section-title-en">Why Fullstack Development?</span></h2><p className="section-subtitle">फुलस्टैक डेवलपमेंट टेक इंडस्ट्री का सबसे तेज़ और भरोसेमंद रास्ता — जॉब-ओरिएंटेड, फ्यूचर-प्रूफ, परफेक्ट।</p></motion.div>
      <div className="why-grid">{whyCards.map((c, i) => (<motion.div key={c.en} className="why-card" {...reveal(0.1 * (i + 1))}><div className="ic">{c.icon}</div><h3>{c.hi}</h3><span className="why-en-tag">{c.en}</span><p>{c.desc}</p></motion.div>))}</div>
      <motion.div className="why-highlight" {...reveal(0.5)}><div className="why-highlight-inner"><FaLightbulb className="why-highlight-icon" /><p><strong>सिर्फ ₹3000 / Only ₹3000</strong> — 6 महीने का कम्प्लीट फुलस्टैक कोर्स। 10+ प्रोजेक्ट्स, AI ट्रेनिंग, 100% जॉब असिस्टेंस। आपके करियर का सबसे अच्छा निवेश।</p></div></motion.div>
