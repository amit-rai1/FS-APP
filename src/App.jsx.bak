    </div></section>
  );
}

/* ======================= TRAINER ======================= */
function Trainer() {
  return (
    <section className="section trainer-section" id="trainer"><div className="container">
      <motion.div className="text-center" {...reveal()}><span className="section-tag">आपके मेंटर / Your Mentor</span><h2 className="section-title"><span className="gradient-text-accent">अमित राय</span> से सीखें<span className="section-title-en">Learn from Amit Rai</span></h2><p className="section-subtitle">इंडस्ट्री-एक्सपीरियंस्ड फुलस्टैक डेवलपर — अगली पीढ़ी के कोडर्स तैयार कर रहे हैं।<br />Industry-experienced fullstack developer mentoring the next generation.</p></motion.div>
      <div className="trainer-wrap">
        <motion.div {...reveal(0.2)}><div className="trainer-photo"><div className="trainer-photo-ring"></div><div className="avatar"><span>AR</span><div className="avatar-status"></div></div></div></motion.div>
        <motion.div className="trainer-info" {...reveal(0.35)}>
          <h3>अमित राय <span className="trainer-name-en">Amit Rai</span></h3>
          <div className="trainer-role">फुलस्टैक डेवलपर और ट्रेनर | Fullstack Developer & Trainer</div>
          <p className="trainer-bio">अमित राय एक उत्साही फुलस्टैक डेवलपर हैं जिनके पास MERN स्टैक का उपयोग करके स्केलेबल वेब एप्लीकेशन बनाने का 3+ वर्षों का इंडस्ट्री अनुभव है। उन्होंने दर्जनों विद्यार्थियों को कॉन्फिडेंट डेवलपर्स बनने में मेंटर किया है।<br /><br />Amit Rai is a passionate MERN stack developer with 3+ years of industry experience. He has mentored dozens of students into confident developers through real-world projects and AI tools.</p>
          <div className="trainer-skills"><span><FaReact /> React</span><span><FaNodeJs /> Node.js</span><span><SiMongodb /> MongoDB</span><span><SiExpress /> Express</span><span><SiTailwindcss /> Tailwind</span><span><FaPython /> Python</span><span><FaGitAlt /> Git</span><span><FaDocker /> Docker</span></div>
          <div className="trainer-meta"><div className="item"><div className="v">3+</div><div className="l">साल / Years Exp.</div></div><div className="item"><div className="v">50+</div><div className="l">विद्यार्थी / Students</div></div><div className="item"><div className="v">20+</div><div className="l">प्रोजेक्ट्स / Projects</div></div></div>
          <div className="trainer-quote"><FaQuoteRight className="quote-icon" /><p>"मेरा मिशन — बलरामपुर के हर BCA-BSc स्टूडेंट को वर्ल्ड-क्लास टेक एजुकेशन, बिल्कुल किफायती फीस में।"</p></div>
        </motion.div>
      </div>
    </div></section>
  );
}

/* ======================= WHY FULLSTACK ======================= */
const whyCards = [
  { icon: <FaBriefcase />, hi: "हाई-पेइंग जॉब्स", en: "High-Paying Jobs", desc: "फुलस्टैक डेवलपर्स भारत और ग्लोबली सबसे ज़्यादा डिमांड और अच्छी सैलरी वाले टेक रोल्स में हैं।" },
